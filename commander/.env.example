# IronClaude Commander Environment Configuration
# Copy to .env and fill in values: cp .env.example .env

# Slack [REQUIRED]
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token
SLACK_CHANNEL_ID=C0123456789

# Slack [OPTIONAL] — for operator message search
SLACK_USER_TOKEN=xoxp-your-slack-user-token
SLACK_OPERATOR_USER_ID=U0123456789

# Operator Identity
OPERATOR_NAME=YourName
AUTONOMY_LEVEL=3

# Database
DB_PATH=data/db/ironclaude.db

# Daemon
POLL_INTERVAL_SECONDS=15
HEARTBEAT_INTERVAL_SECONDS=900

# QE Tools [OPTIONAL] — required only if using QE testing tools
QE_LAUNCH_BIN=/path/to/your/launcher/binary
QE_LAUNCH_PATH=/path/to/your/project
