{
  "name": "state-manager",
  "version": "1.0.0",
  "description": "State management MCP server for Claude Code plugins",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "state-manager-mcp-server": "./cli/mcp-server.mjs"
  },
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:fsevents --external:better-sqlite3",
    "postinstall": "npm rebuild better-sqlite3 2>/dev/null || true",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude-code",
    "state-management",
    "mcp-server"
  ],
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.22.0",
    "better-sqlite3": "^12.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.7.0",
    "esbuild": "^0.25.11",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
