# Node.js — node_modules auto-installed by wrapper on first run
# Only source code and config committed; deps + build artifacts are generated
*.db
.tmp.driveupload
.tmp.drivedownload

# Commander (Python)
__pycache__/
*.pyc
commander/scan/
commander/.env
commander/data/db/*.db
commander/data/db/*.db-shm
commander/data/db/*.db-wal
*.egg-info/
commander/dist/
build/
.pytest_cache/
.venv/
/tmp/ic-*

# Worker plan docs (generated by workers during execution)
docs/plans/
docs/reviews/

# Worker MCP server dependencies and build artifacts (installed by wrapper on first run)
worker/mcp-servers/*/node_modules/
worker/mcp-servers/*/dist/
commander/docs/plans
worker/docs/plans
commander/docs
docs
